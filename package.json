{
  "name": "adaptive-accessibility-intelligence-aai",
  "version": "0.2.0",
  "description": "AI-driven accessibility platform with dynamic content personalization",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && python -m uvicorn app.main:app",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "keywords": [
    "accessibility",
    "ai",
    "a11y",
    "fastapi",
    "react",
    "vite"
  ],
  "author": "078shashank",
  "license": "MIT",
  "devDependencies": {
    "ajv": "~8.18.0",
    "npm-run-all": "~4.1.5"
  }
}
