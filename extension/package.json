{
  "name": "aai-chrome-extension",
  "version": "1.0.0",
  "description": "AAI - Adaptive Accessibility Intelligence Chrome Extension",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:dev": "NODE_ENV=development webpack --config webpack.config.js --watch",
    "build:prod": "NODE_ENV=production webpack --config webpack.config.js",
    "package": "npm run build:prod && bestzip aai-extension-v1.0.0.zip extension/dist/*",
    "lint": "eslint extension/**/*.js",
    "test": "echo \"Tests coming soon\""
  },
  "keywords": [
    "accessibility",
    "chrome-extension",
    "a11y",
    "text-simplification",
    "reading-assistance"
  ],
  "author": "078shashank",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "bestzip": "^2.2.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
